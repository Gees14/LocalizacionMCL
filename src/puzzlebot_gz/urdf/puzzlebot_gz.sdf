<?xml version='1.0'?>
<sdf version='1.9'>
  <model name='puzzlebot'>

    <link name='base_footprint'>
      <inertial>
        <pose>-0.002209 0 0.056279 0 0 0</pose>
        <mass>2.15</mass>
        <inertia>
          <ixx>0.013851</ixx><ixy>0</ixy><ixz>-0.000172</ixz>
          <iyy>0.013492</iyy><iyz>0</iyz><izz>0.020129</izz>
        </inertia>
      </inertial>

      <collision name='base_link_collision'>
        <pose>0 0 0.05 0 0 0</pose>
        <geometry><box><size>0.20 0.15 0.10</size></box></geometry>
      </collision>

      <collision name='caster_collision'>
        <pose>-0.095 0 0.02 0 0 0</pose>
        <geometry><sphere><radius>0.02</radius></sphere></geometry>
        <surface><friction><ode><mu>0.0</mu><mu2>0.0</mu2></ode></friction></surface>
      </collision>

      <collision name='lidar_collision'>
        <pose>0 0 0.20 0 0 0</pose>
        <geometry><cylinder><length>0.04</length><radius>0.04</radius></cylinder></geometry>
      </collision>

      <visual name='base_link_visual'>
        <pose>0 0 0.05 0 0 0</pose>
        <geometry><mesh><uri>model://puzzlebot_description/meshes/Puzzlebot_Jetson_Lidar_Edition_Base.stl</uri></mesh></geometry>
        <material><diffuse>1 0.875 0.125 1</diffuse><ambient>1 0.875 0.125 1</ambient></material>
      </visual>

      <visual name='caster_visual'>
        <pose>-0.095 0 0.02 0 0 0</pose>
        <geometry><mesh><uri>model://puzzlebot_description/meshes/Puzzlebot_Caster_Wheel.stl</uri></mesh></geometry>
        <material><diffuse>0.5 0.5 0.5 1</diffuse><ambient>0.5 0.5 0.5 1</ambient></material>
      </visual>

      <visual name='lidar_visual'>
        <pose>0 0 0.20 0 0 0</pose>
        <geometry><cylinder><length>0.04</length><radius>0.04</radius></cylinder></geometry>
        <material><diffuse>0.3 0.3 0.3 1</diffuse><ambient>0.3 0.3 0.3 1</ambient></material>
      </visual>

      <sensor name='lidar' type='gpu_lidar'>
        <pose>0 0 0.20 0 0 0</pose>
        <update_rate>10</update_rate>
        <visualize>true</visualize>
        <lidar>
          <scan>
            <horizontal>
              <samples>360</samples><resolution>1</resolution>
              <min_angle>-3.14159</min_angle><max_angle>3.14159</max_angle>
            </horizontal>
          </scan>
          <range><min>0.15</min><max>12.0</max><resolution>0.01</resolution></range>
          <noise><type>gaussian</type><mean>0</mean><stddev>0.01</stddev></noise>
        </lidar>
        <topic>/scan</topic>
        <frame_id>lidar_link</frame_id>
      </sensor>
    </link>

    <joint name='wheel_l_joint' type='revolute'>
      <pose relative_to='base_footprint'>0.052 0.095 0.05 0 0 0</pose>
      <parent>base_footprint</parent>
      <child>wheel_l_link</child>
      <axis><xyz>0 1 0</xyz><limit><lower>-inf</lower><upper>inf</upper></limit></axis>
    </joint>

    <link name='wheel_l_link'>
      <pose relative_to='wheel_l_joint'>0 0 0 0 0 0</pose>
      <inertial>
        <mass>0.2</mass>
        <inertia><ixx>0.000125</ixx><ixy>0</ixy><ixz>0</ixz>
                 <iyy>0.000125</iyy><iyz>0</iyz><izz>0.00025</izz></inertia>
      </inertial>
      <collision name='wheel_l_collision'>
        <pose>0 0 0 1.5708 0 3.14159</pose>
        <geometry><cylinder><length>0.03</length><radius>0.05</radius></cylinder></geometry>
        <surface><friction><ode><mu>1.0</mu><mu2>1.0</mu2></ode></friction></surface>
      </collision>
      <visual name='wheel_l_visual'>
        <pose>0 0 0 1.5708 0 3.14159</pose>
        <geometry><mesh><uri>model://puzzlebot_description/meshes/Puzzlebot_Wheel.stl</uri></mesh></geometry>
        <material><diffuse>0.2 0.2 0.2 1</diffuse><ambient>0.2 0.2 0.2 1</ambient></material>
      </visual>
    </link>

    <joint name='wheel_r_joint' type='revolute'>
      <pose relative_to='base_footprint'>0.052 -0.095 0.05 0 0 0</pose>
      <parent>base_footprint</parent>
      <child>wheel_r_link</child>
      <axis><xyz>0 1 0</xyz><limit><lower>-inf</lower><upper>inf</upper></limit></axis>
    </joint>

    <link name='wheel_r_link'>
      <pose relative_to='wheel_r_joint'>0 0 0 0 0 0</pose>
      <inertial>
        <mass>0.2</mass>
        <inertia><ixx>0.000125</ixx><ixy>0</ixy><ixz>0</ixz>
                 <iyy>0.000125</iyy><iyz>0</iyz><izz>0.00025</izz></inertia>
      </inertial>
      <collision name='wheel_r_collision'>
        <pose>0 0 0 1.5708 0 0</pose>
        <geometry><cylinder><length>0.03</length><radius>0.05</radius></cylinder></geometry>
        <surface><friction><ode><mu>1.0</mu><mu2>1.0</mu2></ode></friction></surface>
      </collision>
      <visual name='wheel_r_visual'>
        <pose>0 0 0 1.5708 0 0</pose>
        <geometry><mesh><uri>model://puzzlebot_description/meshes/Puzzlebot_Wheel.stl</uri></mesh></geometry>
        <material><diffuse>0.2 0.2 0.2 1</diffuse><ambient>0.2 0.2 0.2 1</ambient></material>
      </visual>
    </link>

    <!-- DiffDrive: Fortress plugin names (ignition-gazebo6 is the installed bridge backend) -->
    <plugin filename='libignition-gazebo-diff-drive-system.so'
            name='ignition::gazebo::systems::DiffDrive'>
      <left_joint>wheel_l_joint</left_joint>
      <right_joint>wheel_r_joint</right_joint>
      <wheel_separation>0.19</wheel_separation>
      <wheel_radius>0.05</wheel_radius>
      <max_linear_acceleration>1.0</max_linear_acceleration>
      <max_angular_acceleration>2.0</max_angular_acceleration>
      <max_linear_velocity>0.5</max_linear_velocity>
      <max_angular_velocity>2.0</max_angular_velocity>
      <!-- Stop the robot if no cmd_vel arrives within 0.5 s -->
      <cmd_vel_timeout>0.5</cmd_vel_timeout>
    </plugin>

    <!-- JointStatePublisher: Fortress plugin names -->
    <plugin filename='libignition-gazebo-joint-state-publisher-system.so'
            name='ignition::gazebo::systems::JointStatePublisher'>
      <joint_name>wheel_l_joint</joint_name>
      <joint_name>wheel_r_joint</joint_name>
    </plugin>

  </model>
</sdf>
