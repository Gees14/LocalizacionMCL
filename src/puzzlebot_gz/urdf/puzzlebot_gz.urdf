<?xml version="1.0"?>
<robot name="puzzlebot">

  <!--MATERIALS-->
  <material name="yellow">
    <color rgba="0.8 0.7 0.1 1.0"/>
  </material>
  <material name="dark_grey">
    <color rgba="0.2 0.2 0.2 1.0"/>
  </material>
  <material name="grey">
    <color rgba="0.5 0.5 0.5 1.0"/>
  </material>

  <!--LINKS-->

  <link name="base_footprint"/>

  <link name="base_link">
    <visual>
      <origin xyz="0.0 0.0 0.0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://puzzlebot_description/meshes/Puzzlebot_Jetson_Lidar_Edition_Base.stl"/>
      </geometry>
      <material name="yellow"/>
    </visual>
    <collision>
      <origin xyz="0.0 0.0 0.0" rpy="0 0 0"/>
      <geometry><box size="0.20 0.15 0.10"/></geometry>
    </collision>
    <inertial>
      <mass value="2.0"/>
      <origin xyz="0 0 0"/>
      <inertia ixx="0.0116" ixy="0" ixz="0"
                            iyy="0.0108" iyz="0"
                                         izz="0.0196"/>
    </inertial>
  </link>

  <link name="wheel_r_link">
    <visual>
      <origin xyz="0.0 0.0 0.0" rpy="1.5708 0 0"/>
      <geometry>
        <mesh filename="package://puzzlebot_description/meshes/Puzzlebot_Wheel.stl"/>
      </geometry>
      <material name="dark_grey"/>
    </visual>
    <collision>
      <origin xyz="0.0 0.0 0.0" rpy="1.5708 0 0"/>
      <geometry><cylinder length="0.03" radius="0.05"/></geometry>
    </collision>
    <inertial>
      <mass value="0.2"/>
      <origin xyz="0 0 0"/>
      <inertia ixx="0.000125" ixy="0" ixz="0"
                              iyy="0.000125" iyz="0"
                                             izz="0.00025"/>
    </inertial>
  </link>

  <link name="wheel_l_link">
    <visual>
      <origin xyz="0.0 0.0 0.0" rpy="1.5708 0 3.14159"/>
      <geometry>
        <mesh filename="package://puzzlebot_description/meshes/Puzzlebot_Wheel.stl"/>
      </geometry>
      <material name="dark_grey"/>
    </visual>
    <collision>
      <origin xyz="0.0 0.0 0.0" rpy="1.5708 0 3.14159"/>
      <geometry><cylinder length="0.03" radius="0.05"/></geometry>
    </collision>
    <inertial>
      <mass value="0.2"/>
      <origin xyz="0 0 0"/>
      <inertia ixx="0.000125" ixy="0" ixz="0"
                              iyy="0.000125" iyz="0"
                                             izz="0.00025"/>
    </inertial>
  </link>

  <link name="lidar_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><cylinder length="0.04" radius="0.04"/></geometry>
      <material name="grey"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><cylinder length="0.04" radius="0.04"/></geometry>
    </collision>
    <inertial>
      <mass value="0.1"/>
      <origin xyz="0 0 0"/>
      <inertia ixx="0.000033" ixy="0" ixz="0"
                              iyy="0.000033" iyz="0"
                                             izz="0.00008"/>
    </inertial>
  </link>

  <link name="caster_link">
    <visual>
      <origin xyz="0.0 0.0 0.0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://puzzlebot_description/meshes/Puzzlebot_Caster_Wheel.stl"/>
      </geometry>
      <material name="grey"/>
    </visual>
    <collision>
      <origin xyz="0.0 0.0 0.0" rpy="0 0 0"/>
      <geometry><sphere radius="0.02"/></geometry>
    </collision>
    <inertial>
      <mass value="0.05"/>
      <origin xyz="0 0 0"/>
      <inertia ixx="0.000008" ixy="0" ixz="0"
                              iyy="0.000008" iyz="0"
                                             izz="0.000008"/>
    </inertial>
  </link>

  <!--JOINTS-->

  <joint name="base_link_joint" type="fixed">
    <parent link="base_footprint"/>
    <child link="base_link"/>
    <origin xyz="0.0 0.0 0.05" rpy="0 0 0"/>
  </joint>

  <joint name="wheel_r_joint" type="continuous">
    <parent link="base_link"/>
    <child link="wheel_r_link"/>
    <origin xyz="0.052 -0.095 -0.0025" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>

  <joint name="wheel_l_joint" type="continuous">
    <parent link="base_link"/>
    <child link="wheel_l_link"/>
    <origin xyz="0.052 0.095 -0.0025" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>

  <joint name="lidar_joint" type="fixed">
    <parent link="base_link"/>
    <child link="lidar_link"/>
    <origin xyz="0.0 0.0 0.15" rpy="0 0 0"/>
  </joint>

  <joint name="caster_joint" type="fixed">
    <parent link="base_link"/>
    <child link="caster_link"/>
    <origin xyz="-0.095 0.0 -0.03" rpy="0 0 0"/>
  </joint>

  <!--GAZEBO HARMONIC (gz-sim) PLUGINS-->

  <!-- Physics properties for wheels and caster -->
  <gazebo reference="wheel_r_link">
    <mu>1.0</mu>
    <mu2>1.0</mu2>
  </gazebo>
  <gazebo reference="wheel_l_link">
    <mu>1.0</mu>
    <mu2>1.0</mu2>
  </gazebo>
  <gazebo reference="caster_link">
    <mu>0.0</mu>
    <mu2>0.0</mu2>
  </gazebo>

  <!--
    Differential drive plugin for Gazebo Harmonic.
    Subscribes to:  /cmd_vel  (gz topic, bridged from ROS2)
    Publishes to:   /model/puzzlebot/odometry  (gz topic, NOT used for odom)
                    /model/puzzlebot/tf         (gz topic)
    Joint velocities are read via ros_gz_bridge JointState bridge.

    Wheel separation = 0.19 m  (matches URDF joint origins: 0.095 * 2)
    Wheel radius     = 0.05 m
  -->
  <gazebo>
    <plugin filename="gz-sim-diff-drive-system"
            name="gz::sim::systems::DiffDrive">
      <left_joint>wheel_l_joint</left_joint>
      <right_joint>wheel_r_joint</right_joint>
      <wheel_separation>0.19</wheel_separation>
      <wheel_radius>0.05</wheel_radius>
      <max_linear_acceleration>1.0</max_linear_acceleration>
      <max_angular_acceleration>2.0</max_angular_acceleration>
      <max_linear_velocity>0.5</max_linear_velocity>
      <max_angular_velocity>2.0</max_angular_velocity>
      <topic>cmd_vel</topic>
      <odom_topic>odometry</odom_topic>
      <tf_topic>tf</tf_topic>
      <frame_id>odom</frame_id>
      <child_frame_id>base_footprint</child_frame_id>
      <odom_publish_frequency>20</odom_publish_frequency>
    </plugin>
  </gazebo>

  <!-- Joint state publisher — publishes wheel joint positions/velocities -->
  <!-- Bridged by ros_gz_bridge to /joint_states for robot_state_publisher -->
  <gazebo>
    <plugin filename="gz-sim-joint-state-publisher-system"
            name="gz::sim::systems::JointStatePublisher">
      <topic>joint_states</topic>
      <joint_name>wheel_l_joint</joint_name>
      <joint_name>wheel_r_joint</joint_name>
    </plugin>
  </gazebo>

  <!-- LiDAR sensor using gz-sim Sensors system -->
  <gazebo reference="lidar_link">
    <sensor name="lidar" type="gpu_lidar">
      <pose>0 0 0 0 0 0</pose>
      <update_rate>10</update_rate>
      <visualize>true</visualize>
      <lidar>
        <scan>
          <horizontal>
            <samples>360</samples>
            <resolution>1</resolution>
            <min_angle>-3.14159</min_angle>
            <max_angle>3.14159</max_angle>
          </horizontal>
        </scan>
        <range>
          <min>0.15</min>
          <max>12.0</max>
          <resolution>0.01</resolution>
        </range>
        <noise>
          <type>gaussian</type>
          <mean>0.0</mean>
          <stddev>0.01</stddev>
        </noise>
      </lidar>
      <topic>/scan</topic>
      <gz_frame_id>lidar_link</gz_frame_id>
    </sensor>
  </gazebo>

</robot>
